# =============================================================
# Fichier .env unique du projet (utilisé par backend ET docker-compose)
# Copier ce fichier en `.env` puis renseigner les valeurs.
# =============================================================

# --- OpenRouter (LLM) ---
# Clé API disponible sur https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=
OPENROUTER_MODEL=
# Optionnels (utiles pour le classement dans le dashboard OpenRouter) :
OPENROUTER_REFERER=
OPENROUTER_APP_NAME=

# --- Authentification ---
# Jeton partagé pour accéder au back-office (upload, suppression, réindexation).
# Laisser vide pour désactiver l'auth (mode développement uniquement).
# En production, générer avec : openssl rand -hex 32
ADMIN_TOKEN=

# --- Qdrant (base vectorielle) ---
QDRANT_URL=
QDRANT_COLLECTION=
VECTOR_SIZE=

# --- Embeddings ---
EMBEDDING_MODEL=

# --- MinIO (object storage) ---
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_SECURE=
MINIO_RAW_BUCKET=
MINIO_MARKDOWN_BUCKET=

# --- Status store (SQLite) ---
# Chemin vers la base SQLite de suivi d'indexation.
# En développement local : ./data/status.db
# En production Docker   : /app/data/status.db  (monter /app/data en volume)
STATUS_DB_PATH=

# --- Paramètres RAG ---
TOP_K_DENSE=
TOP_K_RERANK=
CHUNK_SIZE=
CHUNK_OVERLAP=

# --- LibreOffice (conversion bureautique → PDF) ---
# Chemin vers l'exécutable LibreOffice si non trouvé automatiquement dans le PATH.
# Exemples :
#   Linux/Docker : /usr/bin/soffice  (installé via le Dockerfile)
#   Windows      : C:\Program Files\LibreOffice\program\soffice.exe
#   macOS        : /Applications/LibreOffice.app/Contents/MacOS/soffice
# Laisser vide pour laisser la détection automatique.
LIBREOFFICE_BIN=

# --- Tesseract OCR ---
# Chemin vers l'exécutable Tesseract si non trouvé automatiquement dans le PATH.
# Exemples :
#   Linux/Docker : /usr/bin/tesseract  (installé via le Dockerfile)
#   Windows      : C:\Program Files\Tesseract-OCR\tesseract.exe
#   macOS        : /usr/local/bin/tesseract  (installé via Homebrew)
# Laisser vide pour laisser la détection automatique.
TESSERACT_BIN=